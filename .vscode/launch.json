{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Next.js: debug (npm run debug)",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "debug"],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "internalConsoleOptions": "neverOpen",
      "skipFiles": ["<node_internals>/**"]
    },
    {
      "name": "Attach to Node (Next main — 9241, matches npm run debug)",
      "type": "node",
      "request": "attach",
      "port": 9241,
      "skipFiles": ["<node_internals>/**"]
    }
  ]
}

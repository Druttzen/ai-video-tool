{
  "version": "1.1.0",
  "app": "ai-video-tool",
  "syncedAt": "2026-06-03",
  "sources": [
    "OpenAI Sora 2 Cookbook (2025)",
    "Runway Gen-4 / Gen-4.5 docs",
    "Kling 2.6 / 3.0 community guides",
    "Google Veo 3 / 3.1 structured prompt patterns",
    "ai-boost/awesome-prompts video_gen_prompting.txt",
    "VidScore AI Video Prompt Guide (2026)",
    "MasterPrompting.net Sora Runway Kling guide",
    "AI Video Bootcamp cinematic prompt matrix (2026)"
  ],
  "principles": [
    "Treat every prompt as a cinematographer's brief: subject, action, camera, environment, lighting, duration.",
    "One primary camera move + one subject action per shot — multiple moves cause jitter.",
    "Separate camera motion from subject motion to avoid confused movement.",
    "Name lens, framing, and light source explicitly — vague 'cinematic' yields randomness.",
    "Shorter clips (4–12s) follow direction more reliably than long single takes.",
    "Music video: map Suno bracket tags → scene beats; cut on chorus/drop.",
    "Audio-first MV: generate Suno track → analyze → BOTH merge → Director render.",
    "Use negative constraints in Rules: no watermark, stable anatomy, no morphing, solid rigid objects.",
    "Image-to-video locks composition; text describes motion and light changes only.",
    "For physics-heavy shots add causal chains: what hits what, and what happens next."
  ],
  "workflows": [
    {
      "id": 1,
      "key": "suno-track",
      "title": "Suno track only",
      "models": ["Director", "Sora 2", "Runway Gen-4"],
      "steps": ["Analyze audio in Analyzers", "Map track → music video", "Director render"]
    },
    {
      "id": 2,
      "key": "suno-paste",
      "title": "Suno paste only",
      "steps": ["Paste Style + Lyrics", "Apply Suno paste → video", "Director render"]
    },
    {
      "id": 3,
      "key": "both",
      "title": "Full sync (track + paste)",
      "steps": ["Track in Analyzers + Suno paste in studio", "BOTH merge", "Director render"]
    },
    {
      "id": 4,
      "key": "manuscript",
      "title": "Manuscript chat",
      "steps": ["Write brief in AI Manuscript Chat", "Apply to project", "Director render"]
    },
    {
      "id": 5,
      "key": "audio-first-mv",
      "title": "Audio-first music video (Suno → Kling/Sora)",
      "steps": [
        "Generate track in Suno",
        "Export WAV → analyze BPM/sections",
        "Timeline script with beat timestamps",
        "Per-beat clips 4–8s → stitch"
      ],
      "source": "Kling 2.6 timeline + Suno workflow"
    },
    {
      "id": 6,
      "key": "keyframe-interpolation",
      "title": "Keyframe interpolation (Veo / i2v)",
      "steps": [
        "Midjourney or still frame for start + end",
        "Upload start/end to i2v model",
        "Prompt describes motion between frames only"
      ],
      "source": "Veo 3.1 interpolation"
    },
    {
      "id": 7,
      "key": "runway-director-mode",
      "title": "Runway Director Mode hybrid",
      "steps": [
        "Text prompt: subject + action + mood only",
        "Use Runway camera panel for pan/tilt/dolly",
        "Motion Brush for foreground/background parallax"
      ],
      "source": "Runway Gen-4.5"
    },
    {
      "id": 8,
      "key": "export-bundle",
      "title": "Export / import project bundle",
      "steps": ["Save Progress locally", "Export Bundle JSON", "Share or re-import on another machine"]
    }
  ],

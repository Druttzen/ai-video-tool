{
  "name": "ai-video-tool",
  "version": "1.0.19",
  "description": "AI Video Creator — Director Engine, standalone video prompt studio, export to any video AI",
  "author": "DJ M@D",
  "private": true,
  "main": "main.js",
  "scripts": {
    "dev": "next dev",
    "debug": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/debug-dev.ps1",
    "stop": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/stop-dev.ps1",
    "cleanup:dist": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/cleanup-locked-electron-dist.ps1",
    "cleanup:dist:admin": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/run-cleanup-elevated.ps1",
    "cleanup:sudo": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/enable-sudo-and-cleanup.ps1",
    "cleanup:dist:sudo": "powershell -NoProfile -ExecutionPolicy Bypass -Command \"sudo powershell -NoProfile -ExecutionPolicy Bypass -File scripts/cleanup-locked-electron-dist.ps1\"",
    "lint": "eslint . --max-warnings 0",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "smoke:desktop": "node scripts/smoke-desktop-setup.cjs",
    "smoke:local-mp4": "node scripts/smoke-local-mp4.cjs --check-only",
    "addons:check": "node scripts/check-addon-updates.cjs",
    "tools:scan": "node scripts/tool-installer.cjs scan",
    "tools:install": "node scripts/install-addons-runner.cjs",
    "tools:protocol": "node scripts/tool-installer.cjs protocol",
    "sync:open-sora-terms": "node scripts/sync-open-sora-terms.cjs",
    "sync:open-sora-catalog": "node scripts/sync-open-sora-catalog.cjs",
    "check": "npm run test && npm run lint && npm run build",
    "build": "next build",
    "electron": "electron .",
    "build:readme-pdf": "node scripts/generate-readme-pdf.cjs",
    "build:installer-license": "node scripts/generate-installer-license.cjs",
    "install-addons": "node scripts/install-addons-runner.cjs",
    "prepare:electron-dist": "node scripts/prep-electron-dist.cjs",
    "dist": "npm run build && npm run build:readme-pdf && npm run build:installer-license && npm run prepare:electron-dist && node scripts/run-electron-builder.cjs"
  },
  "dependencies": {
    "electron-updater": "^6.8.3",
    "lamejs": "^1.2.1",
    "next": "16.2.7",
    "react": "19.0.0",
    "react-dom": "19.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.51.1",
    "@tailwindcss/postcss": "^4.2.4",
    "electron": "41.3.0",
    "electron-builder": "26.8.1",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.2.4",
    "fake-indexeddb": "^6.2.5",
    "pdfkit": "^0.18.0",
    "tailwindcss": "^4.2.4",
    "vitest": "^4.1.8"
  },
  "overrides": {
    "postcss": "^8.5.10"
  },
  "build": {
    "appId": "com.djmad.aivideocreator",
    "productName": "AI Video Creator",
    "files": [
      "main.js",
      "preload.js",
      "out/**/*",
      "icon.ico",
      "scripts/run-director-job.py",
      "scripts/run-open-sora-job.py",
      "scripts/sync-open-sora-catalog.cjs",
      "scripts/lib/environment-scan.cjs",
      "scripts/lib/open-sora-paths.cjs",
      "scripts/lib/addon-paths.cjs",
      "scripts/lib/addon-platform.cjs",
      "scripts/lib/tool-installer.cjs",
      "scripts/lib/setup-hub-console.cjs",
      "scripts/lib/install-console.cjs",
      "scripts/lib/process-exec.cjs",
      "scripts/lib/addon-updater.cjs",
      "scripts/tool-installer.cjs",
      "scripts/install-addons-runner.cjs",
      "scripts/install-addons-pip.py",
      "scripts/wsl-addon-bootstrap.sh",
      "data/addon-updates-manifest.json",
      "data/addon-requirements.txt",
      "data/addon-requirements-optional.txt",
      "data/setup-hub-manifest.json"
    ],
    "asarUnpack": [
      "scripts/**/*.py",
      "scripts/wsl-addon-bootstrap.sh",
      "scripts/install-addons-pip.py"
    ],
    "extraResources": [
      "build/AI_Video_Creator_README.pdf"
    ],
    "extraFiles": [
      {
        "from": "scripts/install-addons.cmd",
        "to": "install-addons.cmd"
      }
    ],
    "directories": {
      "buildResources": "build",
      "output": "electron-dist"
    },
    "win": {
      "target": "nsis",
      "icon": "icon.ico",
      "executableName": "ai-video-tool"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "runAfterFinish": false,
      "include": "build/installer.nsh",
      "license": "build/LICENSE.txt",
      "shortcutName": "AI Video Creator",
      "uninstallDisplayName": "AI Video Creator"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "Druttzen",
        "repo": "ai-video-tool",
        "releaseType": "release"
      }
    ]
  }
}

# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
/test-results/
/playwright-report/

# next.js
/.next/
/out/

# production
/build/*
!/build/
!/build/AI_Video_Creator_README.pdf
!/build/LICENSE.txt
!/build/installer.nsh

# Windows installer / local packaging output (rebuild with npm run dist)
/dist/
/electron-dist/
/electron-dist-*/
/electron-dist-verify/
/verify-dist/
/build/setup-hub-exe/
/build/.electron-dist-output

# Duplicate logo at repo root (canonical copy is public/bones-logo.png)
/bones-logo.png

# Accidental nested folder (not part of this app)
/Druttzen/

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
/.cursor/

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
